#==================================================#
#       AIDA-BOT — Environment Variables           #
#       Copie este arquivo para .env               #
#==================================================#

# ── Servidor ──────────────────────────────────────
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=https://aida.experiasolutions.com.br
DOMAIN_SERVER=https://aida.experiasolutions.com.br
TRUST_PROXY=1
NO_INDEX=true

# ── MongoDB (Atlas Free Tier recomendado) ─────────
# Crie em: https://cloud.mongodb.com → Free M0 → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/AIDA?retryWrites=true&w=majority

# ── Autenticação JWT (gere valores aleatórios!) ──
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Criptografia de Credenciais ───────────────────
# CREDS_KEY: 32 bytes hex | CREDS_IV: 16 bytes hex
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CREDS_KEY=
CREDS_IV=

# ── Groq API (LLM da AIDA) ────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# ── Configurações de Conta ────────────────────────
# Deixe ALLOW_REGISTRATION=true para o MVP (alunos se cadastram)
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_PASSWORD_RESET=true

# ── Email (opcional para MVP) ─────────────────────
# Se não configurar, confirmação de email será desativada
EMAIL_SERVICE=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=

# ── Rate Limiting ─────────────────────────────────
BAN_VIOLATIONS=true
BAN_DURATION=1000
BAN_INTERVAL=20
LOGIN_MAX=7
LOGIN_WINDOW=5
REGISTER_MAX=5
REGISTER_WINDOW=60

# ── Segurança ─────────────────────────────────────
SESSION_EXPIRY=900000
REFRESH_TOKEN_EXPIRY=604800000

# -- Voz (STT e TTS) -------------------------------
# Insira uma chave da OpenAI (para Whisper/TTS) ou ElevenLabs
STT_API_KEY=
OPENAI_API_KEY=
TTS_API_KEY=
ELEVENLABS_API_KEY=
